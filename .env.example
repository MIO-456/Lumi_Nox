# Copy this file to `.env` and fill in your own credentials.
# `.env` is gitignored and must never be committed.
#
# These are only needed to run the realtime engine (realtime_chat.py /
# fast_brain.py). The orchestration core needs no keys at all.

# --- Fast brain (LLM) ---
# doubao ARK key (https://www.volcengine.com/product/doubao)
ARK_API_KEY_FAST=
# Alibaba DashScope key (optional fallback model)
DASHSCOPE_API_KEY=

# --- doubao SC2.0 realtime dialog credentials ---
# App ID / Access Key for the end-to-end realtime voice model.
# Passed into realtime_chat.init(app_id, access_key) by your launcher.
VOLC_DIALOG_APP_ID=
VOLC_DIALOG_ACCESS_KEY=

# --- Optional: realtime built-in web search ---
VOLC_WEBSEARCH_API_KEY=
VOLC_WEBSEARCH_BOT_ID=
